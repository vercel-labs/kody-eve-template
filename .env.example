# --- Resend (email channel + Resend MCP connection) ---
# API key from https://resend.com/api-keys; used by the Chat SDK adapter and as the MCP bearer token.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Signing secret for the `email.received` webhook (Resend dashboard -> Webhooks); verifies inbound email.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender on your Resend domain; compiled into the system prompt at build time (required).
RESEND_FROM_ADDRESS=kody@yourdomain.com
# Sender display name; optional, defaults to "Kody".
RESEND_FROM_NAME=Kody
# Redis connection for @chat-adapter/state-redis (email thread state).
REDIS_URL=redis://default:password@host:6379

# --- Vercel Connect connector UIDs ---
# GitHub App connector; shared by the GitHub channel and the GitHub Tools SDK (maintainer preset).
GITHUB_CONNECTOR=github/kody-agent
# Linear connector; shared by the Linear channel and the Linear MCP connection via linearAuth.
LINEAR_CONNECTOR=linear/kody-agent

# --- Weekly digest schedule ---
# Repository whose open issues are digested, as owner/repo.
DIGEST_REPO=owner/repo
# Recipient of the weekly digest email; replies route back to the agent.
DIGEST_EMAIL=you@example.com
